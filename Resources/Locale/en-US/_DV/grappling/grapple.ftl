grapple-start = Ваші { $part ->
    [hands] руки стискаються навколо
    [jaws] щелепи стискаються навколо
   *[claws] кігті стискаються навколо
} { $victim }!

grapple-start-victim = { $part ->
    [hands] Руки
    [jaws] Щелепи
   *[claws] Кігті
} { $grappler } стискаються навколо вас!


grapple-start-escaping = { $victim } намагається вирватися!
grapple-start-escaping-victim = Ви намагаєтеся вирватися з їхніх { $part ->
    [hands] рук
    [jaws] щелеп
   *[claws] кігтів
}!


grapple-manual-release = Ви обережно відпускаєте { $victim } зі своїх { $part ->
    [hands] рук
    [jaws] щелеп
   *[claws] кігтів
}.

grapple-manual-release-victim = { $grappler } відпускає вас із своїх { $part ->
    [hands] рук
    [jaws] щелеп
   *[claws] кігтів
}.

grapple-finished-escaping = { $victim } виривається з ваших { $part ->
    [hands] рук
    [jaws] щелеп
   *[claws] кігтів
}!

grapple-finished-escaping-victim = Ви вириваєтеся з їхніх { $part ->
    [hands] рук
    [jaws] щелеп
   *[claws] кігтів
}!

grapple-part-hands = рук
grapple-part-jaws = щелеп
grapple-part-claws = кігтів